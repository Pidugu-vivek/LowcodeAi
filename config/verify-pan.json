{
  "id": "verify-pan",
  "version": 1,
  "method": "POST",
  "path": "/verify-pan",
  "description": "Example 1: Verify PAN using Vendor A and, if successful, fetch GST details from Vendor B.",
  "auth": { "type": "none" },
  "request": {
    "schema": {
      "type": "object",
      "required": ["pan"],
      "properties": {
        "pan": { "type": "string", "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]$" }
      }
    }
  },
  "steps": [
    {
      "name": "verifyPan",
      "type": "http",
      "vendor": {
        "baseUrl": "${SELF_BASE_URL}",
        "method": "POST",
        "path": "/mock/vendor-a/verify-pan",
        "timeoutMs": 3000,
        "retry": { "attempts": 3, "backoffMs": 200 }
      },
      "requestMapping": [{ "from": "body.pan", "to": "pan" }],
      "responseMapping": [
        { "from": "body.status", "to": "panStatus" },
        { "from": "body.name", "to": "panName" }
      ]
    },
    {
      "name": "fetchGst",
      "type": "http",
      "condition": { "field": "steps.verifyPan.panStatus", "equals": "VALID" },
      "vendor": {
        "baseUrl": "${SELF_BASE_URL}",
        "method": "POST",
        "path": "/mock/vendor-b/gst",
        "timeoutMs": 3000,
        "retry": { "attempts": 2, "backoffMs": 200 }
      },
      "requestMapping": [{ "from": "body.pan", "to": "pan" }],
      "responseMapping": [
        { "from": "body.gstin", "to": "gstin" },
        { "from": "body.legalName", "to": "legalName" },
        { "from": "body.filingStatus", "to": "filingStatus" }
      ]
    }
  ],
  "response": {
    "mapping": [
      { "from": "steps.verifyPan.panStatus", "to": "panStatus" },
      { "from": "steps.verifyPan.panName", "to": "panName" },
      { "from": "steps.fetchGst.gstin", "to": "gst.gstin" },
      { "from": "steps.fetchGst.legalName", "to": "gst.legalName" },
      { "from": "steps.fetchGst.filingStatus", "to": "gst.filingStatus" }
    ]
  }
}
